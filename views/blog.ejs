<%- include("partials/header", { pageTitle: "Blog" }) %>
<section class="page-hero compact"><div class="container"><h1>Blog</h1><p>Nutrition ideas, product guides, and simple training support.</p></div></section>
<section class="section"><div class="container"><div class="blog-grid"><% allBlogs.forEach((post) => { %><article class="blog-card"><img src="<%= post.image %>" alt="<%= post.title %>"><p><%= post.date %></p><h2><a href="/blog/<%= post.slug %>"><%= post.title %></a></h2><p><%= post.excerpt %></p></article><% }) %></div></div></section>
<%- include("partials/footer") %>
