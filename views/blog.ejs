<%- include("partials/header", { pageTitle: "Blog" }) %>
<section class="page-hero compact blog-hero">
  <div class="container">
    <p class="eyebrow">Protein Market Journal</p>
    <h1>Blog</h1>
    <p>Nutrition ideas, product guides, and simple training support.</p>
  </div>
</section>

<section class="section blog-page">
  <div class="container">
    <div class="blog-grid blog-grid--listing">
      <% allBlogs.forEach((post) => { %>
        <article class="blog-card blog-card--listing">
          <a class="blog-card__media" href="/blog/<%= post.slug %>" aria-label="Read <%= post.title %>">
            <img src="<%= post.image %>" alt="<%= post.title %>" loading="lazy">
          </a>
          <div class="blog-card__body">
            <time datetime="<%= post.date %>"><%= post.date %></time>
            <h2><a href="/blog/<%= post.slug %>"><%= post.title %></a></h2>
            <p><%= post.excerpt %></p>
            <a class="blog-card__link" href="/blog/<%= post.slug %>">Read Article</a>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>
<%- include("partials/footer") %>
