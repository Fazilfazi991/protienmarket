<%- include("partials/header", { pageTitle: "Home" }) %>
<%
  const heroConfig = {
    heroLogoAsset: "/images/protein_main_logo.png",
    heroBottleImage: "/images/hero-protein-jar.webp",
    heroSplashEnabled: true,
    heroSplashAsset: "/images/hero-protein-jar.webp",
    heroAnimationIntensity: "subtle",
    heroAnimationSpeed: "8s"
  };
%>
<section
  class="hero hero-premium"
  data-hero-splash="<%= heroConfig.heroSplashEnabled %>"
  data-hero-intensity="<%= heroConfig.heroAnimationIntensity %>"
  style="--hero-animation-speed: <%= heroConfig.heroAnimationSpeed %>;"
>
  <div class="container hero__grid">
    <div class="hero__copy">
      <p class="eyebrow" data-i18n="home.heroEyebrow">Discover Premium Protein Solutions</p>
      <h1 data-i18n="home.heroTitle">Your One-Stop Destination for All Things Protein</h1>
      <p data-i18n="home.heroSubtitle">Premium quality protein products crafted to fuel your goals and elevate your performance.</p>
      <a class="btn btn--gold" href="/shop" data-i18n="buttons.shopNow">Shop Now</a>
    </div>
    <div class="hero-product" aria-hidden="true">
      <div class="hero-product__splash hero-product__splash--back"></div>
      <div class="hero-product__splash hero-product__splash--mist"></div>
      <div class="hero-product__particles">
        <span></span><span></span><span></span><span></span><span></span>
      </div>
      <div class="hero-product__label">
        <img src="<%= heroConfig.heroLogoAsset %>" alt="">
        <span>Premium Protein</span>
      </div>
    </div>
  </div>
</section>

<section class="shop-goal-section">
  <div class="container">
    <div class="profile-return" data-profile-return hidden></div>
    <div class="section-heading">
      <h2 data-i18n="home.shopByGoal">Shop By Goal</h2>
      <div class="gold-divider" aria-hidden="true"></div>
      <p data-i18n="home.goalIntro">Choose your fitness goal and we'll show the right products, stacks, and meal options.</p>
    </div>
    <%
      const goalImages = {
        "lose-fat": "/images/goals/goal-lose-fat.webp",
        "build-muscle": "/images/goals/goal-build-muscle.webp",
        "stay-fit": "/images/goals/goal-stay-fit.webp",
        "vegan-lifestyle": "/images/goals/goal-vegan-lifestyle.webp",
        "busy-professional": "/images/goals/goal-busy-professional.webp",
        "athlete-recovery": "/images/goals/goal-athlete-recovery.webp"
      };
    %>
    <div class="goal-grid">
      <% goals.forEach((goal) => { %>
        <a class="goal-card" href="/goal/<%= goal.slug %>">
          <div class="goal-card-image">
            <img src="<%= goalImages[goal.slug] %>" alt="<%= goal.title %>" loading="lazy" width="170" height="170" data-i18n-alt="goals.<%= goal.slug %>.title">
          </div>
          <div class="goal-card-content">
            <h3 data-i18n="goals.<%= goal.slug %>.title"><%= goal.title %></h3>
            <p data-i18n="goals.<%= goal.slug %>.description"><%= goal.description %></p>
            <strong class="goal-card-cta"><span data-i18n="buttons.exploreGoal">Explore Goal</span> <span aria-hidden="true">-&gt;</span></strong>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<section class="section categories">
  <div class="container">
    <h2 data-i18n="home.shopByCategory">Shop By Category</h2>
    <div class="title-line"></div>
    <div class="category-row">
      <% const categoryImages = { "vegan-protein": "/images/product-vegan-protein.webp", "protein": "/images/product-whey-protein.webp", "bars-snacks": "/images/product-protein-bars.webp", "fresh-protein": "/images/category-protein-foods.webp", "meal-plan": "/images/product-meal-plan.webp" }; %>
      <% categories.forEach((category) => { %>
        <a class="category" href="/category/<%= category.slug %>">
          <img src="<%= categoryImages[category.slug] %>" alt="<%= category.name %>" loading="lazy">
          <span data-i18n="categories.<%= category.slug %>"><%= category.name %></span>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<section class="section mvp-cta-row">
  <div class="container cta-grid">
    <article class="conversion-card">
      <p class="eyebrow" data-i18n="home.guidedEyebrow">Guided shopping</p>
      <h2 data-i18n="home.guidedTitle">Not sure which protein is right for you?</h2>
      <p data-i18n="home.guidedCopy">Answer 5 quick questions and get product suggestions based on your goal, diet, and routine.</p>
      <div class="button-row"><a class="btn btn--gold" href="/find-my-protein" data-i18n="buttons.startQuiz">Start Quiz</a><a class="btn btn--ghost" href="/protein-calculator" data-i18n="buttons.calculateProtein">Calculate Protein</a></div>
    </article>
    <article class="conversion-card conversion-card--dark">
      <p class="eyebrow" data-i18n="home.bundleEyebrow">Smart bundle</p>
      <h2 data-i18n="home.bundleTitle">Build Your Protein Stack</h2>
      <p data-i18n="home.bundleCopy">Choose your goal and create a simple combo of protein, snacks, and meal support.</p>
      <a class="btn btn--gold" href="/build-your-stack" data-i18n="buttons.buildStack">Build My Stack</a>
    </article>
  </div>
</section>

<section class="section featured">
  <div class="container">
    <h2 data-i18n="home.featuredProducts">Featured Products</h2>
    <div class="title-line"></div>
    <p class="section-intro" data-i18n="home.featuredIntro">Fuel your body with the purity and strength it deserves. Our featured products are designed to support every rep, run, and recovery.</p>
    <div class="carousel-wrap">
      <button class="carousel-arrow left" type="button" data-scroll-products="-1">&lt;</button>
      <div class="product-grid product-grid--featured" data-product-track>
        <% featuredProducts.forEach((product) => { %><%- include("partials/product-card", { product }) %><% }) %>
      </div>
      <button class="carousel-arrow right" type="button" data-scroll-products="1">&gt;</button>
    </div>
  </div>
</section>

<section class="section consultation">
  <div class="container split">
    <div>
      <h2 data-i18n="home.consultTitle">One on one Health coach/ Personal Consultation</h2>
      <p data-i18n="home.consultCopy1">At Protein Market, we believe that true strength comes from within and it starts with the right nutrition. Our mission is simple: to empower every individual to achieve their best by providing clean, high-quality protein products that fuel ambition and support a healthier lifestyle.</p>
      <p data-i18n="home.consultCopy2">Join us on this journey to redefine strength and well-being. Because when you fuel better, you feel better.</p>
      <div class="button-row">
        <a class="btn btn--gold" href="/contact" data-i18n="nav.consult">Consult Now</a>
        <a class="btn btn--insta" href="https://instagram.com/" target="_blank" rel="noreferrer">Instagram</a>
        <a class="btn btn--whatsapp" href="https://wa.me/971553271712" target="_blank" rel="noreferrer" data-i18n="buttons.chatWithUs">Chat With us</a>
      </div>
    </div>
    <img class="wide-image" src="/images/section-consultation.webp" alt="Personal nutrition consultation" loading="lazy">
  </div>
</section>

<section class="section why">
  <div class="container">
    <h2 data-i18n="home.whyTitle">Why Choose Us?</h2>
    <p class="section-intro" data-i18n="home.whyIntro">Choosing the right protein is not just about the label, it is about trust, quality, and results. Here is why The Protein Market is your ideal choice for premium protein products.</p>
    <div class="why-grid">
      <article><span><svg viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 4.7-2.8 8.8-7 10-4.2-1.2-7-5.3-7-10V6l7-3z"/><path d="M8.5 12l2.2 2.2 4.8-5"/></svg></span><div><h3 data-i18n="home.qualityTitle">Quality Guaranteed</h3><p data-i18n="home.qualityCopy">Only the finest ingredients, pure, potent, and rigorously tested for quality.</p></div></article>
      <article><span><svg viewBox="0 0 24 24"><path d="M3 7h11v9H3z"/><path d="M14 10h4l3 3v3h-7z"/><circle cx="7" cy="18" r="2"/><circle cx="18" cy="18" r="2"/></svg></span><div><h3 data-i18n="home.deliveryTitle">UAE-Wide Delivery</h3><p data-i18n="home.deliveryCopy">Fast and reliable delivery to your doorstep, anywhere in the UAE.</p></div></article>
      <article><span><svg viewBox="0 0 24 24"><path d="M20 4c-8 0-14 5-14 12 0 2 1 3 1 3s1-5 7-8"/><path d="M20 4c0 8-5 14-12 14"/></svg></span><div><h3 data-i18n="home.freshnessTitle">Freshness & Sustainability</h3><p data-i18n="home.freshnessCopy">Packed for peak freshness with sustainable practices you can trust.</p></div></article>
      <article><span><svg viewBox="0 0 24 24"><path d="M7 8h10"/><path d="M5 6v4"/><path d="M19 6v4"/><path d="M9 14h6"/><path d="M12 10v9"/></svg></span><div><h3 data-i18n="home.mealPlansTitle">Fitness-Focused Meal Plans</h3><p data-i18n="home.mealPlansCopy">Expertly crafted meal plans to fuel your workouts and support your goals.</p></div></article>
    </div>
  </div>
</section>

<section class="journey">
  <img src="/images/section-fitness-cta.webp" alt="Athlete drinking protein" loading="lazy">
  <div>
    <h2 data-i18n="home.journeyTitle">Ready to Transform Your Fitness Journey?</h2>
    <p data-i18n="home.journeyCopy">Discover the power of clean, high-quality protein designed to fuel your workouts, enhance recovery, and elevate your daily nutrition.</p>
    <a class="btn btn--gold" href="/shop" data-i18n="buttons.startTransformation">Start Your Transformation Today -></a>
  </div>
</section>

<section class="section blog-preview">
  <div class="container">
    <h2 data-i18n="home.blogTitle">Insights on Protein, Health, and Fitness</h2>
    <p data-i18n="home.blogIntro">In today&apos;s fast-paced world, maintaining a healthy lifestyle is more important than ever. Stay tuned for expert tips, nutritional insights, and fitness strategies.</p>
    <div class="blog-grid">
      <% featuredBlogs.forEach((post) => { %>
        <article class="blog-card">
          <img src="<%= post.image %>" alt="<%= post.title %>" loading="lazy" data-i18n-alt="blogs.<%= post.slug %>.title">
          <div><time><%= post.date %></time><h3 data-i18n="blogs.<%= post.slug %>.title"><%= post.title %></h3><p data-i18n="blogs.<%= post.slug %>.excerpt"><%= post.excerpt %></p><a href="/blog/<%= post.slug %>" data-i18n="buttons.readMore">READ MORE</a></div>
        </article>
      <% }) %>
    </div>
  </div>
</section>
<%- include("partials/footer") %>
