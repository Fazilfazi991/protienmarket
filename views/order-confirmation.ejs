<%- include("partials/header", { pageTitle: order.id }) %>
<section class="section checkout-section">
  <div class="container payment-result">
    <div class="checkout-card">
      <h1>Order <%= order.id %></h1>
      <p>Status: <strong><%= order.orderStatus %></strong></p>
      <p>Payment: <strong><%= order.payment.status %></strong></p>
      <div class="order-lines"><% order.items.forEach((item) => { %><div><span><%= item.name %> x <%= item.quantity %></span><span class="price-block"><strong class="price-aed ltr-value">AED <%= money(item.lineTotal) %></strong><% if (shopConfig.displayUsdPrices) { %><span class="price-usd ltr-value">≈ $<%= usd(item.lineTotal) %></span><% } %></span></div><% }) %></div>
      <div class="summary-line total"><span data-i18n="cart.total">Total</span><span class="price-block"><strong class="price-aed ltr-value">AED <%= money(order.total) %></strong><% if (shopConfig.displayUsdPrices) { %><span class="price-usd ltr-value">≈ $<%= usd(order.total) %></span><% } %></span></div>
      <% if (shopConfig.displayUsdPrices) { %><p class="usd-note" data-i18n="currency.usdNote">USD shown for reference. Checkout is charged in AED.</p><% } %>
    </div>
  </div>
</section>
<%- include("partials/footer") %>
