    </div>
  </footer>
  <% const footerShopConfig = typeof shopConfig !== "undefined" ? shopConfig : { displayUsdPrices: true, aedToUsdRate: 0.2723, currency: "AED" }; const footerTranslations = typeof translations !== "undefined" ? translations : { en: {}, ar: {} }; %>
  <script>
    window.PRODUCTS = <%- JSON.stringify(products) %>;
    window.SHOP_CONFIG = <%- JSON.stringify(footerShopConfig) %>;
    window.TRANSLATIONS = <%- JSON.stringify(footerTranslations) %>;
    window.COACH_PRODUCTS = <%- JSON.stringify(products.map((product) => ({
      id: product.id,
      name: product.name,
      nameAr: product.nameAr || "",
      description: product.description,
      descriptionAr: product.descriptionAr || "",
      slug: product.slug,
      category: product.category,
      subcategory: product.subcategory,
      image: product.image,
      price: product.price,
      tags: product.tags || [],
      goals: product.goals || [],
      diet: product.diet || []
    }))) %>;
    window.COACH_WHATSAPP_NUMBER = "<%= whatsappNumber %>";
  </script>
