<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof pageTitle !== "undefined" ? pageTitle + " | " : "" %>Protein Market</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="topbar">
    <div class="container topbar__inner">
      <span>support@protein.com</span>
      <span>+971 55 327 1712</span>
    </div>
  </div>
  <header class="site-header">
    <div class="container nav">
      <a class="logo" href="/" aria-label="Protein Market home">
        <img src="/images/protein_main_logo.png" alt="Protein Market">
      </a>
      <button class="hamburger" type="button" aria-label="Open menu" data-menu-toggle>
        <span></span><span></span><span></span>
      </button>
      <nav class="nav__links" data-nav>
        <div class="shop-menu">
          <a class="shop-menu__trigger" href="/shop" data-shop-toggle>Shop <span class="chevron" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="m6 9 6 6 6-6"/></svg></span></a>
          <div class="mega-menu" data-mega-menu>
            <div class="container mega-menu__grid">
              <% categories.forEach((category) => { %>
                <div class="mega-menu__column">
                  <a class="mega-menu__heading" href="/category/<%= category.slug %>"><%= category.name %></a>
                  <% category.children.forEach((child) => { %>
                    <a class="mega-menu__link" href="/category/<%= category.slug %>/<%= child.slug %>"><%= child.name %></a>
                  <% }) %>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
        <a href="/about">About Us</a>
        <a href="/find-my-protein">Find My Protein</a>
        <a href="/contact">Contact Us</a>
        <a href="/blog">Blog</a>
        <a href="/faq">FAQs</a>
      </nav>
      <div class="nav__actions">
        <a class="pill pill--gold" href="/contact">Consult Now</a>
        <a class="pill pill--gold-dark" href="/protein-calculator">Protein Calc</a>
        <button class="icon-btn" type="button" aria-label="Account"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c1.4-4.2 4-6 8-6s6.6 1.8 8 6"/></svg></button>
        <a class="icon-btn cart-link" href="/cart" aria-label="Cart"><svg viewBox="0 0 24 24"><path d="M4 5h2l2 11h10l2-8H7"/><circle cx="10" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/></svg><span data-cart-count>0</span></a>
        <button class="icon-btn" type="button" aria-label="Search" data-search-open><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="6"/><path d="M16 16l5 5"/></svg></button>
      </div>
    </div>
  </header>
  <div class="search-overlay" data-search-overlay>
    <form class="search-box" action="/shop" method="get">
      <button type="button" class="search-close" data-search-close aria-label="Close search">x</button>
      <label for="search-input">Search products</label>
      <input id="search-input" name="q" type="search" placeholder="Protein, bars, meal plan...">
      <button class="btn btn--gold" type="submit">Search</button>
    </form>
  </div>
  <main>
