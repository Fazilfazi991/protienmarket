<!doctype html>
<html lang="<%= locale || 'en' %>" dir="<%= dir || 'ltr' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof pageTitle !== "undefined" ? pageTitle + " | " : seo.title %></title>
  <meta name="description" content="<%= seo.description %>">
  <link rel="canonical" href="<%= seo.canonicalPath %>">
  <link rel="alternate" hreflang="en" href="<%= seo.alternateEn %>">
  <link rel="alternate" hreflang="ar" href="<%= seo.alternateAr %>">
  <link rel="alternate" hreflang="x-default" href="<%= seo.alternateEn %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Sora:wght@500;600;700;800&family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="lang-<%= locale %> dir-<%= dir %>">
  <div class="topbar">
    <div class="container topbar__inner">
      <span class="ltr-value">support@protein.com</span>
      <span class="ltr-value">+971 55 327 1712</span>
    </div>
  </div>
  <header class="site-header">
    <div class="container nav">
      <a class="logo" href="<%= localePath('/') %>" aria-label="Protein Market home">
        <img src="/images/protein_main_logo.png" alt="Protein Market">
      </a>
      <button class="hamburger" type="button" aria-label="Open menu" data-menu-toggle>
        <span></span><span></span><span></span>
      </button>
      <nav class="nav__links" data-nav>
        <div class="shop-menu">
          <a class="shop-menu__trigger" href="<%= localePath('/shop') %>" data-shop-toggle><span data-i18n="nav.shop"><%= t('nav.shop') %></span> <span class="chevron" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="m6 9 6 6 6-6"/></svg></span></a>
          <div class="mega-menu" data-mega-menu>
            <div class="container mega-menu__grid">
              <% categories.forEach((category) => { %>
                <div class="mega-menu__column">
                  <a class="mega-menu__heading" href="<%= localePath('/category/' + category.slug) %>" data-i18n="categories.<%= category.slug %>"><%= t('categories.' + category.slug, category.name) %></a>
                  <% category.children.forEach((child) => { %>
                    <a class="mega-menu__link" href="<%= localePath('/category/' + category.slug + '/' + child.slug) %>" data-i18n="categories.<%= child.slug %>"><%= t('categories.' + child.slug, child.name) %></a>
                  <% }) %>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
        <a href="<%= localePath('/about') %>" data-i18n="nav.about"><%= t('nav.about') %></a>
        <a href="<%= localePath('/find-my-protein') %>" data-i18n="nav.findProtein"><%= t('nav.findProtein') %></a>
        <a href="<%= localePath('/contact') %>" data-i18n="nav.contact"><%= t('nav.contact') %></a>
        <a href="<%= localePath('/blog') %>" data-i18n="nav.blog"><%= t('nav.blog') %></a>
        <div class="language-switch language-switch--mobile" aria-label="Language switcher">
          <a class="<%= locale === 'en' ? 'is-active' : '' %>" href="<%= switchLocalePath('en') %>" hreflang="en" data-lang-link="en">English</a>
          <a class="<%= locale === 'ar' ? 'is-active' : '' %>" href="<%= switchLocalePath('ar') %>" hreflang="ar" data-lang-link="ar">العربية</a>
        </div>
      </nav>
      <div class="nav__actions">
        <div class="language-switch" aria-label="Language switcher">
          <a class="<%= locale === 'en' ? 'is-active' : '' %>" href="<%= switchLocalePath('en') %>" hreflang="en" data-lang-link="en">English</a>
          <a class="<%= locale === 'ar' ? 'is-active' : '' %>" href="<%= switchLocalePath('ar') %>" hreflang="ar" data-lang-link="ar">العربية</a>
        </div>
        <a class="pill pill--gold-dark" href="<%= localePath('/protein-calculator') %>" data-i18n="nav.proteinCalc"><%= t('nav.proteinCalc') %></a>
        <button class="icon-btn" type="button" aria-label="<%= t('nav.account') %>" data-i18n-aria-label="nav.account"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c1.4-4.2 4-6 8-6s6.6 1.8 8 6"/></svg></button>
        <a class="icon-btn cart-link" href="<%= localePath('/cart') %>" aria-label="<%= t('nav.cart') %>" data-i18n-aria-label="nav.cart"><svg viewBox="0 0 24 24"><path d="M4 5h2l2 11h10l2-8H7"/><circle cx="10" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/></svg><span data-cart-count>0</span></a>
        <button class="icon-btn" type="button" aria-label="<%= t('nav.search') %>" data-i18n-aria-label="nav.search" data-search-open><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="6"/><path d="M16 16l5 5"/></svg></button>
      </div>
    </div>
  </header>
  <div class="search-overlay" data-search-overlay>
    <form class="search-box" action="<%= localePath('/shop') %>" method="get">
      <button type="button" class="search-close" data-search-close aria-label="Close search">x</button>
      <label for="search-input" data-i18n="nav.search"><%= t('nav.search') %></label>
      <input id="search-input" name="q" type="search" placeholder="<%= t('forms.searchPlaceholder') %>" data-i18n-placeholder="forms.searchPlaceholder">
      <button class="btn btn--gold" type="submit" data-i18n="nav.search"><%= t('nav.search') %></button>
    </form>
  </div>
  <main>
