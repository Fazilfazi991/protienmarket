<article class="product-card" data-product-card data-product-url="<%= localePath('/product/' + product.slug) %>" data-name="<%= product.name.toLowerCase() %>" data-name-en="<%= product.name %>" data-name-ar="<%= product.nameAr || "" %>" data-description-en="<%= product.description %>" data-description-ar="<%= product.descriptionAr || "" %>" data-price="<%= product.price %>" data-rating="<%= product.rating %>" data-sale="<%= product.sale %>" data-category="<%= product.category %>" data-category-key="<%= product.category %>" data-subcategory="<%= product.subcategory %>" data-badges="<%= (product.badges || []).join("|") %>" data-tags="<%= (product.tags || []).join("|") %>" data-goals="<%= (product.goals || []).join("|") %>" data-bundle="<%= product.bundle || "" %>" data-stock="<%= product.inStock !== false %>">
  <% const displayUsd = typeof shopConfig !== "undefined" ? shopConfig.displayUsdPrices : true; const usdValue = typeof usd === "function" ? usd(product.price) : money(Number(product.price) * 0.2723); %>
  <% if (product.sale) { %><span class="sale">SALE!</span><% } %>
  <a href="<%= localePath('/product/' + product.slug) %>"><img src="<%= product.image %>" alt="<%= isArabic && product.nameAr ? product.nameAr : product.name %>" loading="lazy"></a>
  <% const cardCategory = categories.find((item) => item.slug === product.category); %>
  <span class="product-card__category" data-category-label><%= t('categories.' + product.category, cardCategory ? cardCategory.name : product.category) %></span>
  <h3><a href="<%= localePath('/product/' + product.slug) %>" data-product-name><%= isArabic && product.nameAr ? product.nameAr : product.name %></a></h3>
  <div class="stars" aria-label="<%= product.rating %> out of 5 stars">
    <% for (let i = 1; i <= 5; i += 1) { %><span class="<%= i <= Math.round(product.rating) ? "filled" : "" %>">&#9733;</span><% } %>
  </div>
  <p class="product-card__description" data-product-description><%= isArabic && product.descriptionAr ? product.descriptionAr : product.description %></p>
  <p class="price">
    <% if (product.oldPrice) { %><del class="ltr-value">AED <%= money(product.oldPrice) %></del><% } %>
    <span class="price-block"><strong class="price-aed ltr-value">AED <%= money(product.price) %></strong><% if (displayUsd) { %><span class="price-usd ltr-value">≈ $<%= usdValue %></span><% } %></span>
  </p>
  <button class="btn btn--small btn--gold" data-add-to-cart="<%= product.id %>" data-i18n="buttons.addToCart"><%= t('buttons.addToCart') %></button>
  <a class="view-details" href="<%= localePath('/product/' + product.slug) %>" data-i18n="buttons.viewDetails"><%= t('buttons.viewDetails') %></a>
</article>
