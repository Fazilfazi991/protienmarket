<div class="protein-coach" data-protein-coach>
  <div class="coach-tooltip" data-coach-tooltip>Need help choosing?</div>
  <button class="coach-fab" type="button" aria-label="Open Protein Coach" data-coach-toggle>
    <img class="coach-fab__character" src="/images/protein-coach-character.png" alt="" aria-hidden="true">
    <span class="coach-fab__text">Protein Coach</span>
    <span class="coach-fab__dot" aria-hidden="true"></span>
  </button>
  <aside class="coach-panel" data-coach-panel hidden>
    <header class="coach-header">
      <div class="coach-avatar" aria-hidden="true">
        <img src="/images/protein-coach-character.png" alt="">
      </div>
      <div>
        <h2>Protein Coach</h2>
        <p>Find the right product in 30 seconds</p>
      </div>
      <button class="coach-icon-btn" type="button" aria-label="Close Protein Coach" data-coach-close>
        <svg viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </header>
    <div class="coach-body" data-coach-body></div>
  </aside>
</div>
